{
  "name": "@starter/backend",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "type-check": "tsc --noEmit",
    "lint": "eslint src/",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "dependencies": {
    "@starter/shared": "workspace:*",

    "zod": "^3.24.0",
    "dotenv": "^16.4.0",

    "cors": "^2.8.5",
    "express": "^4.21.0",
    "express-rate-limit": "^7.4.0",

    "@supabase/supabase-js": "^2.47.0"
  },
  "devDependencies": {
    "@starter/eslint-config": "workspace:*",
    "@starter/prettier-config": "workspace:*",
    "typescript": "^5.7.0",
    "@typescript-eslint/parser": "^8.56.0",

    "vitest": "^2",
    "@vitest/coverage-v8": "^2",

    "eslint": "^9",
    "prettier": "^3.4.0",

    "tsx": "^4.19.0",

    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.0",
    "@types/node": "^22.0.0"
  }
}
